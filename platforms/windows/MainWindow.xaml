<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="Seyfr.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Seyfr"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="Seyfr">

    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

    <Grid x:Name="RootGrid" Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">
        <Grid.Resources>
            <local:TabBackgroundConverter x:Key="TabBackgroundConverter" />
            <local:TabForegroundConverter x:Key="TabForegroundConverter" />
            <SolidColorBrush x:Key="HoverBrush" Color="#E8F4FD" />
            
            <Style x:Key="NavButtonStyle" TargetType="Button">
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="RootBorder"
                                Background="{TemplateBinding Background}"
                                BorderThickness="0"
                                CornerRadius="{TemplateBinding CornerRadius}"
                                Padding="{TemplateBinding Padding}">
                                <VisualStateManager.VisualStateGroups>
                                    <VisualStateGroup x:Name="CommonStates">
                                        <VisualState x:Name="Normal" />
                                        <VisualState x:Name="PointerOver">
                                            <VisualState.Setters>
                                                <Setter Target="RootBorder.Background" Value="{StaticResource HoverBrush}" />
                                            </VisualState.Setters>
                                        </VisualState>
                                        <VisualState x:Name="Pressed" />
                                        <VisualState x:Name="Disabled" />
                                    </VisualStateGroup>
                                </VisualStateManager.VisualStateGroups>
                                <ContentPresenter 
                                    Content="{TemplateBinding Content}"
                                    ContentTemplate="{TemplateBinding ContentTemplate}"
                                    HorizontalContentAlignment="{TemplateBinding HorizontalContentAlignment}"
                                    VerticalContentAlignment="{TemplateBinding VerticalContentAlignment}" />
                            </Border>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>
            <local:TabTitleConverter x:Key="TabTitleConverter" />
            <local:TabSubtitleConverter x:Key="TabSubtitleConverter" />
            <local:TabVisibilityConverter x:Key="TabVisibilityConverter" />
            <local:InverseBoolToVisibilityConverter x:Key="InverseBoolToVisibilityConverter" />
            <local:BoolToFontWeightConverter x:Key="BoolToFontWeightConverter" TrueValue="SemiBold" FalseValue="Normal" />
            <local:BoolToFontWeightConverter x:Key="InverseBoolToFontWeightConverter" TrueValue="Normal" FalseValue="SemiBold" />
            <local:FolderModeGlyphConverter x:Key="FolderModeGlyphConverter" />
        </Grid.Resources>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- Sidebar -->
        <Grid Grid.Column="0" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="0,0,1,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Logo -->
            <StackPanel Grid.Row="0"
            Margin="30,42,24,38"
            Spacing="22"
            HorizontalAlignment="Left">

                <Border Width="76"
            Height="76"
            CornerRadius="38"
            BorderBrush="{ThemeResource TextFillColorPrimaryBrush}"
            BorderThickness="2"
            HorizontalAlignment="Left">

                    <TextBlock Text="S"
                   FontSize="28"
                   FontWeight="SemiBold"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center" />
                </Border>

                <StackPanel Spacing="8"
                HorizontalAlignment="Left">

                    <TextBlock Text="SEYFR"
                   FontSize="36"
                   FontWeight="Light"
                   CharacterSpacing="180"
                   TextAlignment="Left"
                   HorizontalAlignment="Left" />

                    <TextBlock Text="Send Your Files Right"
                   FontSize="12"
                   FontWeight="SemiBold"
                   CharacterSpacing="120"
                   Opacity="0.62"
                   TextAlignment="Left"
                   HorizontalAlignment="Left" />
                </StackPanel>
            </StackPanel>

            <!-- Navigation -->
            <StackPanel Grid.Row="1" Margin="16,0">
                <!-- Send Button -->
                <Button x:Name="SendNavButton"
        HorizontalAlignment="Stretch"
        HorizontalContentAlignment="Left"
        Padding="14,12"
        CornerRadius="14"
        BorderThickness="0"
        Background="{Binding SelectedTab, Converter={StaticResource TabBackgroundConverter}, ConverterParameter=Send, Mode=OneWay}"
        Style="{StaticResource NavButtonStyle}">

                    <StackPanel Orientation="Horizontal" Spacing="14">

                        <!-- Icon Bubble -->
                        <Border Width="30"
                Height="30"
                CornerRadius="15"
                Background="{Binding SelectedTab, Converter={StaticResource TabBackgroundConverter}, ConverterParameter=Send}">

                            <FontIcon Glyph="&#xE898;"
                      FontSize="15"
                      Foreground="White"
                      HorizontalAlignment="Center"
                      VerticalAlignment="Center" />
                        </Border>

                        <TextBlock Text="Send"
                   FontSize="15"
                   FontWeight="SemiBold"
                   VerticalAlignment="Center"
                   Foreground="{Binding SelectedTab, Converter={StaticResource TabForegroundConverter}, ConverterParameter=Send}" />
                    </StackPanel>
                </Button>

                <!-- Receive Button -->
                <Button x:Name="ReceiveNavButton"
                     HorizontalAlignment="Stretch"
                     HorizontalContentAlignment="Left"
                     Padding="14,12"
                     CornerRadius="14"
                     BorderThickness="0"
                     Margin="0,8,0,0"
                     Background="{Binding SelectedTab, Converter={StaticResource TabBackgroundConverter}, ConverterParameter=Receive, Mode=OneWay}"
                     Style="{StaticResource NavButtonStyle}">

                    <StackPanel Orientation="Horizontal" Spacing="14">

                        <!-- Icon Bubble -->
                        <Border Width="30"
                            Height="30"
                            CornerRadius="15"
                            Background="{Binding SelectedTab, Converter={StaticResource TabBackgroundConverter}, ConverterParameter=Receive}">

                            <FontIcon Glyph="&#xE896;"
                                FontSize="15"
                                Foreground="White"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center" />
                        </Border>

                        <TextBlock Text="Receive"
                            FontSize="15"
                            FontWeight="SemiBold"
                            VerticalAlignment="Center"
                            Foreground="{Binding SelectedTab, Converter={StaticResource TabForegroundConverter}, ConverterParameter=Receive}" />
                    </StackPanel>
                </Button>
            </StackPanel>

            <!-- Status -->
            <StackPanel Grid.Row="2" Margin="24,16" Spacing="4">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <Ellipse Width="8" Height="8" Fill="{ThemeResource SystemFillColorSuccessBrush}" />
                    <TextBlock Text="Online" FontSize="12" FontWeight="SemiBold" />
                </StackPanel>
                <TextBlock Text="Ready to send files" FontSize="11" Opacity="0.6" />
            </StackPanel>
        </Grid>

        <!-- Main Content -->
        <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto">
            <Grid Margin="40,32">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <!-- Header -->
                <StackPanel Grid.Row="0" HorizontalAlignment="Center" Margin="0,0,0,32" Spacing="8">
                    <TextBlock Text="{Binding SelectedTab, Converter={StaticResource TabTitleConverter}, Mode=OneWay}" FontSize="28" FontWeight="SemiBold" HorizontalAlignment="Center" />
                    <TextBlock Text="{Binding SelectedTab, Converter={StaticResource TabSubtitleConverter}, Mode=OneWay}" FontSize="13" Opacity="0.6" HorizontalAlignment="Center" />
                </StackPanel>

                <!-- Send View -->
                <StackPanel Grid.Row="1"
            Spacing="24"
            HorizontalAlignment="Center"
            MaxWidth="600"
            Visibility="{Binding SelectedTab, Converter={StaticResource TabVisibilityConverter}, ConverterParameter=Send, Mode=OneWay}">

                    <!-- Drop Area -->
                    <StackPanel Spacing="16"
                HorizontalAlignment="Center">

                        <Grid Width="280"
              Height="280">

                            <!-- Rings -->
                            <Canvas Width="280"
                    Height="280">

                                <Ellipse Canvas.Left="20"
                         Canvas.Top="20"
                         Width="240"
                         Height="240"
                         Stroke="{ThemeResource TextFillColorSecondaryBrush}"
                         StrokeThickness="0.5"
                         Opacity="0.15" />

                                <Ellipse Canvas.Left="40"
                         Canvas.Top="40"
                         Width="200"
                         Height="200"
                         Stroke="{ThemeResource TextFillColorSecondaryBrush}"
                         StrokeThickness="0.5"
                         Opacity="0.15" />

                                <Ellipse Canvas.Left="60"
                         Canvas.Top="60"
                         Width="160"
                         Height="160"
                         Stroke="{ThemeResource TextFillColorSecondaryBrush}"
                         StrokeThickness="0.5"
                         Opacity="0.15" />

                                <Ellipse Canvas.Left="80"
                         Canvas.Top="80"
                         Width="120"
                         Height="120"
                         Stroke="{ThemeResource TextFillColorSecondaryBrush}"
                         StrokeThickness="0.5"
                         Opacity="0.15" />

                                <Ellipse Canvas.Left="100"
                         Canvas.Top="100"
                         Width="80"
                         Height="80"
                         Stroke="{ThemeResource TextFillColorSecondaryBrush}"
                         StrokeThickness="0.5"
                         Opacity="0.15" />
                            </Canvas>

                            <FontIcon Glyph="{Binding IsFolderMode, Converter={StaticResource FolderModeGlyphConverter}}"
                                    FontSize="40"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center" />
                        </Grid>

                        <StackPanel Spacing="4"
                    HorizontalAlignment="Center">

                            <TextBlock Text="Drag &amp; drop files here"
                       FontSize="14"
                       Opacity="0.6"
                       HorizontalAlignment="Center" />

                            <HyperlinkButton Content="or click to browse"
                             FontSize="14"
                             HorizontalAlignment="Center" />
                        </StackPanel>

                        <!-- Toggle -->
                        <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Center"
                            Spacing="12">

                            <TextBlock Text="File mode"
                                FontSize="13"
                                VerticalAlignment="Center"
                                FontWeight="{Binding IsFolderMode, Converter={StaticResource InverseBoolToFontWeightConverter}}" />

                            <ToggleSwitch IsOn="{Binding IsFolderMode, Mode=TwoWay}"
                                OnContent="Folder mode"
                                OffContent="File mode" />
                        </StackPanel>

                        <!-- Footer -->
                        <StackPanel Orientation="Horizontal"
                    HorizontalAlignment="Center"
                    Spacing="8"
                    Margin="0,24,0,0"
                    Opacity="0.5">

                            <FontIcon Glyph="&#xE72E;" FontSize="14" />

                            <TextBlock Text="Your files are end-to-end encrypted"
                       FontSize="12" />
                        </StackPanel>
                    </StackPanel>
                </StackPanel>

                <!-- Receive View -->
                <StackPanel Grid.Row="1"
            Spacing="24"
            HorizontalAlignment="Center"
            MaxWidth="760"
            Visibility="{Binding SelectedTab, Converter={StaticResource TabVisibilityConverter}, ConverterParameter=Receive, Mode=OneWay}">

                    <!-- Ticket Card -->
                    <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
            BorderThickness="1"
            CornerRadius="18"
            Padding="24"
            Width="720">

                        <StackPanel Spacing="18">

                            <Grid>
                                <TextBlock Text="Enter ticket"
                           FontSize="18"
                           FontWeight="SemiBold"
                           VerticalAlignment="Center" />

                                <Button Content="Paste"
                        HorizontalAlignment="Right"
                        Padding="14,8"
                        CornerRadius="10"
                        Background="Transparent"
                        BorderThickness="0.5" />
                            </Grid>

                            <TextBox PlaceholderText="Paste ticket here..."
                     AcceptsReturn="True"
                     MinHeight="72"
                     TextWrapping="Wrap"
                     Padding="12"
                     FontFamily="Consolas"
                     FontSize="13"
                     CornerRadius="12" />
                        </StackPanel>
                    </Border>

                    <!-- Save Location Card -->
                    <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
            BorderThickness="1"
            CornerRadius="18"
            Padding="24"
            Width="720">

                        <StackPanel Spacing="18">

                            <Grid>
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <FontIcon Glyph="&#xE8B7;" FontSize="18" />
                                    <TextBlock Text="Save Location"
                               FontSize="18"
                               FontWeight="SemiBold" />
                                </StackPanel>

                                <Button Content="Change"
                        HorizontalAlignment="Right"
                        Background="Transparent"
                        BorderThickness="0" />
                            </Grid>

                            <Border Background="{ThemeResource LayerFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="14"
                    Padding="16">

                                <StackPanel Orientation="Horizontal" Spacing="14">
                                    <FontIcon Glyph="&#xE8B7;" FontSize="20" />

                                    <StackPanel>
                                        <TextBlock Text="Documents"
                                   FontSize="15"
                                   FontWeight="SemiBold" />

                                        <TextBlock Text="{Binding DestinationPath, Mode=OneWay}"
                                   FontSize="13"
                                   Opacity="0.6"
                                   TextTrimming="CharacterEllipsis" />
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Border>

                    <!-- Receive Button -->
                    <Button Content="Receive File"
            HorizontalAlignment="Stretch"
            Padding="16,12"
            CornerRadius="14"
            Command="{Binding ReceiveCommand, Mode=OneWay}"
            Style="{StaticResource AccentButtonStyle}" />

                    <TextBlock Text="Once you enter a valid ticket, the files will be ready to download."
               FontSize="13"
               Opacity="0.55"
               HorizontalAlignment="Center"
               TextAlignment="Center"
               TextWrapping="Wrap" />
                </StackPanel>
            </Grid>
        </ScrollViewer>

    </Grid>
</Window>