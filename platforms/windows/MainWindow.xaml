<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="Seyfr.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Seyfr"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="Seyfr"
    Width="1000" Height="900" MinWidth="800" MinHeight="700">

    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

    <Grid x:Name="RootGrid" Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">
        <Grid.Resources>
            <local:TabBackgroundConverter x:Key="TabBackgroundConverter" />
            <local:TabTitleConverter x:Key="TabTitleConverter" />
            <local:TabSubtitleConverter x:Key="TabSubtitleConverter" />
            <local:TabVisibilityConverter x:Key="TabVisibilityConverter" />
            <local:InverseBoolToVisibilityConverter x:Key="InverseBoolToVisibilityConverter" />
            <local:BoolToFontWeightConverter x:Key="BoolToFontWeightConverter" TrueValue="SemiBold" FalseValue="Normal" />
            <local:BoolToFontWeightConverter x:Key="InverseBoolToFontWeightConverter" TrueValue="Normal" FalseValue="SemiBold" />
        </Grid.Resources>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- Sidebar -->
        <Grid Grid.Column="0" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="0,0,1,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Logo -->
            <StackPanel Grid.Row="0" Margin="24,32,24,24" Spacing="12">
                <Border Width="48" Height="48" CornerRadius="24" BorderBrush="{ThemeResource TextFillColorPrimaryBrush}" BorderThickness="1">
                    <TextBlock Text="S" FontSize="20" FontWeight="SemiBold" HorizontalAlignment="Center" VerticalAlignment="Center" />
                </Border>
                <StackPanel Spacing="4">
                    <TextBlock Text="SEYFR" FontSize="20" FontWeight="Light" CharacterSpacing="40" />
                    <TextBlock Text="Send Your Files Right" FontSize="11" Opacity="0.6" />
                </StackPanel>
            </StackPanel>

            <!-- Navigation -->
            <StackPanel Grid.Row="1" Margin="16,0">
                <!-- Send Button -->
                <Button x:Name="SendNavButton" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left" Padding="12,10" CornerRadius="8" BorderThickness="0" Background="{x:Bind ViewModel.SelectedTab, Converter={StaticResource TabBackgroundConverter}, ConverterParameter=Send, Mode=OneWay}">
                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <FontIcon Glyph="&#xE898;" FontSize="16" />
                        <TextBlock Text="Send" FontSize="14" />
                    </StackPanel>
                </Button>

                <!-- Receive Button -->
                <Button x:Name="ReceiveNavButton" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left" Padding="12,10" CornerRadius="8" BorderThickness="0" Margin="0,4,0,0" Background="{x:Bind ViewModel.SelectedTab, Converter={StaticResource TabBackgroundConverter}, ConverterParameter=Receive, Mode=OneWay}">
                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <FontIcon Glyph="&#xE896;" FontSize="16" />
                        <TextBlock Text="Receive" FontSize="14" />
                    </StackPanel>
                </Button>
            </StackPanel>

            <!-- Status -->
            <StackPanel Grid.Row="2" Margin="24,16" Spacing="4">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <Ellipse Width="8" Height="8" Fill="{ThemeResource SystemFillColorSuccessBrush}" />
                    <TextBlock Text="Online" FontSize="12" FontWeight="SemiBold" />
                </StackPanel>
                <TextBlock Text="Ready to send files" FontSize="11" Opacity="0.6" />
            </StackPanel>
        </Grid>

        <!-- Main Content -->
        <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto">
            <Grid Margin="40,32">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <!-- Header -->
                <StackPanel Grid.Row="0" HorizontalAlignment="Center" Margin="0,0,0,32" Spacing="8">
                    <TextBlock Text="{x:Bind ViewModel.SelectedTab, Converter={StaticResource TabTitleConverter}, Mode=OneWay}" FontSize="28" FontWeight="SemiBold" HorizontalAlignment="Center" />
                    <TextBlock Text="{x:Bind ViewModel.SelectedTab, Converter={StaticResource TabSubtitleConverter}, Mode=OneWay}" FontSize="13" Opacity="0.6" HorizontalAlignment="Center" />
                </StackPanel>

                <!-- Send View -->
                <StackPanel Grid.Row="1" Spacing="24" HorizontalAlignment="Center" MaxWidth="600"
                            Visibility="{x:Bind ViewModel.SelectedTab, Converter={StaticResource TabVisibilityConverter}, ConverterParameter=Send, Mode=OneWay}">

                    <!-- File Card -->
                    <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="12" Padding="16"
                            Visibility="{x:Bind ViewModel.HasSelectedFile, Mode=OneWay}">
                        <StackPanel Orientation="Horizontal" Spacing="12">
                            <Grid Width="40" Height="40" Background="{ThemeResource AccentFillColorDefaultBrush}" CornerRadius="20">
                                <FontIcon Glyph="&#xE73E;" FontSize="18" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Grid>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="{x:Bind ViewModel.SelectedFileName, Mode=OneWay}" FontSize="14" FontWeight="SemiBold" />
                                <TextBlock Text="Ready to send" FontSize="12" Opacity="0.6" />
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- Drop Area -->
                    <StackPanel Spacing="16" HorizontalAlignment="Center"
                                Visibility="{x:Bind ViewModel.HasSelectedFile, Converter={StaticResource InverseBoolToVisibilityConverter}, Mode=OneWay}">
                        <Grid x:Name="DropArea" Width="280" Height="280" AllowDrop="True" DragOver="DropArea_DragOver" Drop="DropArea_Drop">
                            <!-- Concentric Rings -->
                            <Canvas Width="280" Height="280" HorizontalAlignment="Center" VerticalAlignment="Center">
                                <Ellipse Canvas.Left="20" Canvas.Top="20" Width="240" Height="240" Stroke="{ThemeResource TextFillColorSecondaryBrush}" StrokeThickness="0.5" Opacity="0.3" />
                                <Ellipse Canvas.Left="40" Canvas.Top="40" Width="200" Height="200" Stroke="{ThemeResource TextFillColorSecondaryBrush}" StrokeThickness="0.5" Opacity="0.3" />
                                <Ellipse Canvas.Left="60" Canvas.Top="60" Width="160" Height="160" Stroke="{ThemeResource TextFillColorSecondaryBrush}" StrokeThickness="0.5" Opacity="0.3" />
                                <Ellipse Canvas.Left="80" Canvas.Top="80" Width="120" Height="120" Stroke="{ThemeResource TextFillColorSecondaryBrush}" StrokeThickness="0.5" Opacity="0.3" />
                                <Ellipse Canvas.Left="100" Canvas.Top="100" Width="80" Height="80" Stroke="{ThemeResource TextFillColorSecondaryBrush}" StrokeThickness="0.5" Opacity="0.3" />
                            </Canvas>
                            <FontIcon Glyph="&#xE7C3;" FontSize="32" HorizontalAlignment="Center" VerticalAlignment="Center" />
                            <Border x:Name="DropHighlight" BorderBrush="{ThemeResource AccentFillColorDefaultBrush}" BorderThickness="2" CornerRadius="20" Opacity="0" />
                        </Grid>

                        <StackPanel Spacing="4" HorizontalAlignment="Center">
                            <TextBlock Text="Drag &amp; drop files here" FontSize="14" Opacity="0.6" HorizontalAlignment="Center" />
                            <HyperlinkButton Content="or click to browse" FontSize="14" Click="BrowseButton_Click" HorizontalAlignment="Center" />
                        </StackPanel>

                        <!-- Mode Toggle -->
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="12">
                            <TextBlock Text="File mode" FontSize="13" VerticalAlignment="Center"
                                       FontWeight="{x:Bind ViewModel.IsFolderMode, Converter={StaticResource InverseBoolToFontWeightConverter}, Mode=OneWay}" />
                            <ToggleSwitch x:Name="ModeToggle" IsOn="{x:Bind ViewModel.IsFolderMode, Mode=TwoWay}" />
                            <TextBlock Text="Folder mode" FontSize="13" VerticalAlignment="Center"
                                       FontWeight="{x:Bind ViewModel.IsFolderMode, Converter={StaticResource BoolToFontWeightConverter}, Mode=OneWay}" />
                        </StackPanel>
                    </StackPanel>

                    <!-- Ticket Card -->
                    <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="12" Padding="20"
                            Visibility="{x:Bind ViewModel.HasTicket, Mode=OneWay}">
                        <StackPanel Spacing="16">
                            <Grid>
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <FontIcon Glyph="&#xE8A1;" FontSize="16" />
                                    <TextBlock Text="Transfer Ticket" FontSize="15" FontWeight="SemiBold" VerticalAlignment="Center" />
                                </StackPanel>
                                <Button Content="Clear" FontSize="12" Padding="10,6" CornerRadius="8" BorderThickness="0.5" BorderBrush="{ThemeResource TextFillColorSecondaryBrush}" Background="Transparent" HorizontalAlignment="Right"
                                        Command="{x:Bind ViewModel.ClearSendCommand, Mode=OneWay}" />
                            </Grid>
                            <Border Background="White" CornerRadius="8" Padding="16" HorizontalAlignment="Center">
                                <TextBlock Text="QR Code Placeholder" FontSize="12" Opacity="0.5" />
                            </Border>
                            <TextBlock Text="{x:Bind ViewModel.Ticket, Mode=OneWay}" FontSize="11" FontFamily="Consolas" TextWrapping="Wrap" Opacity="0.8" />
                            <Grid ColumnSpacing="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Button Grid.Column="0" Content="Copy" Padding="12,8" CornerRadius="8" BorderThickness="0.5" BorderBrush="{ThemeResource TextFillColorSecondaryBrush}" Background="Transparent" HorizontalAlignment="Stretch"
                                        Command="{x:Bind ViewModel.CopyTicketCommand, Mode=OneWay}" />
                                <Button Grid.Column="1" Content="Share" Padding="12,8" CornerRadius="8" BorderThickness="0.5" BorderBrush="{ThemeResource TextFillColorSecondaryBrush}" Background="Transparent" HorizontalAlignment="Stretch" />
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- Send Button -->
                    <Button Content="Send File" HorizontalAlignment="Stretch" Padding="16,12" CornerRadius="10"
                            Command="{x:Bind ViewModel.SendCommand, Mode=OneWay}"
                            Visibility="{x:Bind ViewModel.HasSelectedFile, Mode=OneWay}"
                            Style="{StaticResource AccentButtonStyle}" />

                    <!-- Status -->
                    <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8" Padding="12,8"
                            Visibility="{x:Bind ViewModel.HasStatus, Mode=OneWay}">
                        <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Center">
                            <FontIcon Glyph="&#xE73E;" FontSize="14" />
                            <TextBlock Text="{x:Bind ViewModel.Status, Mode=OneWay}" FontSize="13" />
                        </StackPanel>
                    </Border>

                    <!-- Footer -->
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="8" Opacity="0.5">
                        <FontIcon Glyph="&#xE8D4;" FontSize="14" />
                        <TextBlock Text="Your files are end-to-end encrypted" FontSize="12" />
                    </StackPanel>
                </StackPanel>

                <!-- Receive View -->
                <StackPanel Grid.Row="1" Spacing="24" HorizontalAlignment="Center" MaxWidth="600"
                            Visibility="{x:Bind ViewModel.SelectedTab, Converter={StaticResource TabVisibilityConverter}, ConverterParameter=Receive, Mode=OneWay}">

                    <!-- Concentric Rings (decorative) -->
                    <Grid Width="280" Height="280" HorizontalAlignment="Center">
                        <Canvas Width="280" Height="280">
                            <Ellipse Canvas.Left="20" Canvas.Top="20" Width="240" Height="240" Stroke="{ThemeResource TextFillColorSecondaryBrush}" StrokeThickness="0.5" Opacity="0.3" />
                            <Ellipse Canvas.Left="40" Canvas.Top="40" Width="200" Height="200" Stroke="{ThemeResource TextFillColorSecondaryBrush}" StrokeThickness="0.5" Opacity="0.3" />
                            <Ellipse Canvas.Left="60" Canvas.Top="60" Width="160" Height="160" Stroke="{ThemeResource TextFillColorSecondaryBrush}" StrokeThickness="0.5" Opacity="0.3" />
                            <Ellipse Canvas.Left="80" Canvas.Top="80" Width="120" Height="120" Stroke="{ThemeResource TextFillColorSecondaryBrush}" StrokeThickness="0.5" Opacity="0.3" />
                            <Ellipse Canvas.Left="100" Canvas.Top="100" Width="80" Height="80" Stroke="{ThemeResource TextFillColorSecondaryBrush}" StrokeThickness="0.5" Opacity="0.3" />
                        </Canvas>
                        <FontIcon Glyph="&#xE896;" FontSize="32" HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Grid>

                    <!-- Ticket Card -->
                    <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="12" Padding="20">
                        <StackPanel Spacing="14">
                            <Grid>
                                <TextBlock Text="Enter ticket" FontSize="15" FontWeight="SemiBold" VerticalAlignment="Center" />
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8">
                                    <Button Content="Paste" FontSize="12" Padding="10,6" CornerRadius="8" BorderThickness="0.5" BorderBrush="{ThemeResource TextFillColorSecondaryBrush}" Background="Transparent"
                                            Command="{x:Bind ViewModel.PasteTicketCommand, Mode=OneWay}" />
                                    <Button Content="Clear" FontSize="12" Padding="10,6" CornerRadius="8" BorderThickness="0.5" BorderBrush="{ThemeResource TextFillColorSecondaryBrush}" Background="Transparent"
                                            Command="{x:Bind ViewModel.ClearTicketCommand, Mode=OneWay}"
                                            Visibility="{x:Bind ViewModel.HasTicketInput, Mode=OneWay}" />
                                </StackPanel>
                            </Grid>
                            <TextBox Text="{x:Bind ViewModel.TicketInput, Mode=TwoWay}" PlaceholderText="Paste ticket here..." TextWrapping="Wrap" AcceptsReturn="True" MinHeight="80" Padding="10" BorderBrush="{ThemeResource TextFillColorSecondaryBrush}" BorderThickness="0.5" CornerRadius="8" FontFamily="Consolas" FontSize="11" />
                        </StackPanel>
                    </Border>

                    <!-- Destination Card -->
                    <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="12" Padding="20">
                        <StackPanel Spacing="14">
                            <Grid>
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <FontIcon Glyph="&#xE8B7;" FontSize="16" />
                                    <TextBlock Text="Save Location" FontSize="15" FontWeight="SemiBold" VerticalAlignment="Center" />
                                </StackPanel>
                                <Button Content="Change" FontSize="12" Padding="10,6" CornerRadius="8" BorderThickness="0.5" BorderBrush="{ThemeResource TextFillColorSecondaryBrush}" Background="Transparent" HorizontalAlignment="Right"
                                        Command="{x:Bind ViewModel.SelectDestinationCommand, Mode=OneWay}" />
                            </Grid>
                            <Border Background="{ThemeResource LayerFillColorDefaultBrush}" CornerRadius="8" Padding="16">
                                <StackPanel Spacing="4">
                                    <TextBlock Text="Documents" FontSize="14" FontWeight="SemiBold" />
                                    <TextBlock Text="{x:Bind ViewModel.DestinationPath, Mode=OneWay}" FontSize="12" Opacity="0.6" TextTrimming="CharacterEllipsis" />
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Border>

                    <!-- Receive Button -->
                    <Button Content="Receive File" HorizontalAlignment="Stretch" Padding="16,12" CornerRadius="10"
                            Command="{x:Bind ViewModel.ReceiveCommand, Mode=OneWay}"
                            Style="{StaticResource AccentButtonStyle}" />

                    <!-- Status -->
                    <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8" Padding="12,8"
                            Visibility="{x:Bind ViewModel.HasStatus, Mode=OneWay}">
                        <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Center">
                            <FontIcon Glyph="&#xE73E;" FontSize="14" />
                            <TextBlock Text="{x:Bind ViewModel.Status, Mode=OneWay}" FontSize="13" />
                        </StackPanel>
                    </Border>

                    <TextBlock Text="Once you enter a valid ticket, the files will be ready to download." FontSize="12" Opacity="0.5" HorizontalAlignment="Center" TextAlignment="Center" TextWrapping="Wrap" />
                </StackPanel>
            </Grid>
        </ScrollViewer>
    </Grid>
</Window>
