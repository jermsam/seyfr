<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="Seyfr.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Seyfr"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="Seyfr">

    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

    <Grid x:Name="RootGrid" Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">
        <Grid.Resources>
            <local:TabBackgroundConverter x:Key="TabBackgroundConverter" />
            <local:TabForegroundConverter x:Key="TabForegroundConverter" />
            <SolidColorBrush x:Key="HoverBrush" Color="#F5F5F5" />
            
            <Style x:Key="NavButtonStyle" TargetType="Button">
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="RootBorder"
                                Background="{TemplateBinding Background}"
                                BorderThickness="0"
                                CornerRadius="{TemplateBinding CornerRadius}"
                                Padding="{TemplateBinding Padding}">
                                <VisualStateManager.VisualStateGroups>
                                    <VisualStateGroup x:Name="CommonStates">
                                        <VisualState x:Name="Normal" />
                                        <VisualState x:Name="PointerOver">
                                            <VisualState.Setters>
                                                <Setter Target="RootBorder.Background" Value="{StaticResource HoverBrush}" />
                                            </VisualState.Setters>
                                        </VisualState>
                                        <VisualState x:Name="Pressed" />
                                        <VisualState x:Name="Disabled" />
                                    </VisualStateGroup>
                                </VisualStateManager.VisualStateGroups>
                                <ContentPresenter 
                                    Content="{TemplateBinding Content}"
                                    ContentTemplate="{TemplateBinding ContentTemplate}"
                                    HorizontalContentAlignment="{TemplateBinding HorizontalContentAlignment}"
                                    VerticalContentAlignment="{TemplateBinding VerticalContentAlignment}" />
                            </Border>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>
            <local:TabTitleConverter x:Key="TabTitleConverter" />
            <local:TabSubtitleConverter x:Key="TabSubtitleConverter" />
            <local:TabVisibilityConverter x:Key="TabVisibilityConverter" />
            <local:InverseBoolToVisibilityConverter x:Key="InverseBoolToVisibilityConverter" />
            <local:BoolToFontWeightConverter x:Key="BoolToFontWeightConverter" TrueValue="SemiBold" FalseValue="Normal" />
            <local:BoolToFontWeightConverter x:Key="InverseBoolToFontWeightConverter" TrueValue="Normal" FalseValue="SemiBold" />
            <local:FolderModeGlyphConverter x:Key="FolderModeGlyphConverter" />
            <local:IconBubbleBackgroundConverter x:Key="IconBubbleBackgroundConverter" />
            <local:TabFontWeightConverter x:Key="TabFontWeightConverter" />
            <local:TabStatusTextConverter x:Key="TabStatusTextConverter" />
            <local:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter" />
            <local:BoolToStatusTextConverter x:Key="BoolToStatusTextConverter" />
            <local:BoolToOpacityConverter x:Key="BoolToOpacityConverter" />
            <local:InverseBoolToOpacityConverter x:Key="InverseBoolToOpacityConverter" />
        </Grid.Resources>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- Sidebar -->
        <Grid Grid.Column="0" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="0,0,1,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Logo -->
            <StackPanel Grid.Row="0"
            Margin="16,20,16,32"
            Spacing="12"
            HorizontalAlignment="Left">

                <Border Width="44"
            Height="44"
            CornerRadius="22"
            BorderBrush="{ThemeResource TextFillColorPrimaryBrush}"
            BorderThickness="1.2"
            HorizontalAlignment="Left">

                    <TextBlock Text="S"
                   FontSize="20"
                   FontWeight="Medium"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center" />
                </Border>

                <StackPanel Spacing="4"
                HorizontalAlignment="Left">

                    <TextBlock Text="SEYFR"
                   FontSize="22"
                   FontWeight="Light"
                   CharacterSpacing="136"
                   TextAlignment="Left"
                   HorizontalAlignment="Left" />

                    <TextBlock Text="Send Your Files Right"
                   FontSize="11"
                   FontWeight="Normal"
                   CharacterSpacing="91"
                   Opacity="0.6"
                   TextAlignment="Left"
                   HorizontalAlignment="Left" />
                </StackPanel>
            </StackPanel>

            <!-- Navigation -->
            <StackPanel Grid.Row="1" Margin="12,0" Spacing="4">
                <!-- Send Button -->
                <local:HandCursorButton x:Name="SendNavButton"
        HorizontalAlignment="Stretch"
        HorizontalContentAlignment="Left"
        Padding="12,8"
        CornerRadius="8"
        BorderThickness="0"
        Background="{Binding SelectedTab, Converter={StaticResource TabBackgroundConverter}, ConverterParameter=Send, Mode=OneWay}"
        Style="{StaticResource NavButtonStyle}">

                    <StackPanel Orientation="Horizontal" Spacing="10">

                        <Border Width="28"
                                Height="28"
                                CornerRadius="14"
                                Background="{Binding SelectedTab, Converter={StaticResource IconBubbleBackgroundConverter}, ConverterParameter=Send}"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center">
                            <FontIcon Glyph="&#xE898;"
                                      FontSize="12"
                                      Foreground="White"
                                      HorizontalAlignment="Center"
                                      VerticalAlignment="Center" />
                        </Border>

                        <TextBlock Text="Send"
                   FontSize="14"
                   FontWeight="{Binding SelectedTab, Converter={StaticResource TabFontWeightConverter}, ConverterParameter=Send}"
                   VerticalAlignment="Center"
                   Foreground="{Binding SelectedTab, Converter={StaticResource TabForegroundConverter}, ConverterParameter=Send}" />
                    </StackPanel>
                </local:HandCursorButton>

                <!-- Receive Button -->
                <local:HandCursorButton x:Name="ReceiveNavButton"
                     HorizontalAlignment="Stretch"
                     HorizontalContentAlignment="Left"
                     Padding="12,8"
                     CornerRadius="8"
                     BorderThickness="0"
                     Background="{Binding SelectedTab, Converter={StaticResource TabBackgroundConverter}, ConverterParameter=Receive, Mode=OneWay}"
                     Style="{StaticResource NavButtonStyle}">

                    <StackPanel Orientation="Horizontal" Spacing="10">

                        <Border Width="28"
                                Height="28"
                                CornerRadius="14"
                                Background="{Binding SelectedTab, Converter={StaticResource IconBubbleBackgroundConverter}, ConverterParameter=Receive}"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center">
                            <FontIcon Glyph="&#xE896;"
                                      FontSize="12"
                                      Foreground="White"
                                      HorizontalAlignment="Center"
                                      VerticalAlignment="Center" />
                        </Border>

                        <TextBlock Text="Receive"
                            FontSize="14"
                            FontWeight="{Binding SelectedTab, Converter={StaticResource TabFontWeightConverter}, ConverterParameter=Receive}"
                            VerticalAlignment="Center"
                            Foreground="{Binding SelectedTab, Converter={StaticResource TabForegroundConverter}, ConverterParameter=Receive}" />
                    </StackPanel>
                </local:HandCursorButton>
            </StackPanel>

            <!-- Status -->
            <StackPanel Grid.Row="2" Margin="16,16" Spacing="6">
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <Ellipse Width="8" Height="8" Fill="{ThemeResource SystemFillColorSuccessBrush}" />
                    <TextBlock Text="Online" FontSize="12" FontWeight="SemiBold" />
                </StackPanel>
                <TextBlock Text="{Binding SelectedTab, Converter={StaticResource TabStatusTextConverter}, Mode=OneWay}" FontSize="11" Opacity="0.6" />
            </StackPanel>
        </Grid>

        <!-- Main Content -->
        <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto">
            <Grid Margin="40,32">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <!-- Header -->
                <StackPanel Grid.Row="0" HorizontalAlignment="Center" Margin="0,0,0,32" Spacing="8">
                    <TextBlock Text="{Binding SelectedTab, Converter={StaticResource TabTitleConverter}, Mode=OneWay}" FontSize="28" FontWeight="SemiBold" HorizontalAlignment="Center" />
                    <TextBlock Text="{Binding SelectedTab, Converter={StaticResource TabSubtitleConverter}, Mode=OneWay}" FontSize="13" Opacity="0.6" HorizontalAlignment="Center" />
                </StackPanel>

                <!-- Send View -->
                <StackPanel Grid.Row="1"
            Spacing="24"
            HorizontalAlignment="Stretch"
            MaxWidth="720"
            Visibility="{Binding SelectedTab, Converter={StaticResource TabVisibilityConverter}, ConverterParameter=Send, Mode=OneWay}">

                    <!-- Drop Area -->
                    <StackPanel Spacing="16"
                HorizontalAlignment="Stretch"
                Visibility="{Binding HasSelectedFile, Converter={StaticResource InverseBoolToVisibilityConverter}, Mode=OneWay}">

                        <Grid MinHeight="280"
              HorizontalAlignment="Stretch"
              AllowDrop="True"
              DragOver="DropArea_DragOver"
              DragLeave="DropArea_DragLeave"
              DragEnter="DropArea_DragEnter"
              Drop="DropArea_Drop">

                            <!-- Rings -->
                            <Canvas Width="280"
                    Height="280"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center">

                                <Ellipse Canvas.Left="23"
                         Canvas.Top="23"
                         Width="234"
                         Height="234"
                         Stroke="{ThemeResource TextFillColorSecondaryBrush}"
                         StrokeThickness="0.5"
                         Opacity="0.1" />

                                <Ellipse Canvas.Left="34"
                         Canvas.Top="34"
                         Width="212"
                         Height="212"
                         Stroke="{ThemeResource TextFillColorSecondaryBrush}"
                         StrokeThickness="0.5"
                         Opacity="0.1" />

                                <Ellipse Canvas.Left="45"
                         Canvas.Top="45"
                         Width="190"
                         Height="190"
                         Stroke="{ThemeResource TextFillColorSecondaryBrush}"
                         StrokeThickness="0.5"
                         Opacity="0.1" />

                                <Ellipse Canvas.Left="56"
                         Canvas.Top="56"
                         Width="168"
                         Height="168"
                         Stroke="{ThemeResource TextFillColorSecondaryBrush}"
                         StrokeThickness="0.5"
                         Opacity="0.1" />

                                <Ellipse Canvas.Left="67"
                         Canvas.Top="67"
                         Width="146"
                         Height="146"
                         Stroke="{ThemeResource TextFillColorSecondaryBrush}"
                         StrokeThickness="0.5"
                         Opacity="0.1" />

                                <Ellipse Canvas.Left="78"
                         Canvas.Top="78"
                         Width="124"
                         Height="124"
                         Stroke="{ThemeResource TextFillColorSecondaryBrush}"
                         StrokeThickness="0.5"
                         Opacity="0.1" />

                                <Ellipse Canvas.Left="89"
                         Canvas.Top="89"
                         Width="102"
                         Height="102"
                         Stroke="{ThemeResource TextFillColorSecondaryBrush}"
                         StrokeThickness="0.5"
                         Opacity="0.1" />

                                <Ellipse Canvas.Left="100"
                         Canvas.Top="100"
                         Width="80"
                         Height="80"
                         Stroke="{ThemeResource TextFillColorSecondaryBrush}"
                         StrokeThickness="0.5"
                         Opacity="0.1" />
                            </Canvas>

                            <FontIcon Glyph="{Binding IsFolderMode, Converter={StaticResource FolderModeGlyphConverter}}"
                                    FontSize="28"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center" />
                            <!-- Drag-over accent ring overlay -->
                            <Border x:Name="DragOverlay"
                                    CornerRadius="20"
                                    BorderThickness="2"
                                    BorderBrush="{StaticResource AccentBorderBrush}"
                                    Opacity="0"
                                    IsHitTestVisible="False" />
                        </Grid>

                        <StackPanel Spacing="4"
                    HorizontalAlignment="Center">

                            <TextBlock Text="Drag &amp; drop files here"
                       FontSize="14"
                       Opacity="0.6"
                       HorizontalAlignment="Center" />

                            <local:HandCursorButton Content="or click to browse"
                             FontSize="14"
                             FontWeight="Medium"
                             HorizontalAlignment="Center"
                             Click="BrowseButton_Click"
                             Background="Transparent"
                             BorderThickness="0"
                             Padding="0" />
                        </StackPanel>

                        <!-- Toggle -->
                        <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Center"
                            Spacing="12">

                            <TextBlock Text="File mode"
                                FontSize="13"
                                VerticalAlignment="Center"
                                FontWeight="{Binding IsFolderMode, Converter={StaticResource InverseBoolToFontWeightConverter}}"
                                Opacity="{Binding IsFolderMode, Converter={StaticResource InverseBoolToOpacityConverter}}" />

                            <ToggleSwitch IsOn="{Binding IsFolderMode, Mode=TwoWay}"
                                OnContent=""
                                OffContent=""
                                MinWidth="0"
                                Width="40" />

                            <TextBlock Text="Folder mode"
                                FontSize="13"
                                VerticalAlignment="Center"
                                FontWeight="{Binding IsFolderMode, Converter={StaticResource BoolToFontWeightConverter}}"
                                Opacity="{Binding IsFolderMode, Converter={StaticResource BoolToOpacityConverter}}" />
                        </StackPanel>

                    </StackPanel>

                    <!-- File Card -->
                    <Border Visibility="{Binding HasSelectedFile, Converter={StaticResource BoolToVisibilityConverter}, Mode=OneWay}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="16"
                Padding="16,14"
                HorizontalAlignment="Stretch">

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <!-- Progress / Check -->
                            <Grid Grid.Column="0" Width="40" Height="40" HorizontalAlignment="Center" VerticalAlignment="Center">
                                <ProgressRing IsActive="{Binding IsBusy, Mode=OneWay}"
                                  Width="40"
                                  Height="40"
                                  Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibilityConverter}, Mode=OneWay}"
                                  Foreground="{ThemeResource TextFillColorPrimaryBrush}"
                                  Background="Transparent" />
                                <Ellipse Width="40"
                         Height="40"
                         Stroke="{ThemeResource TextFillColorSecondaryBrush}"
                         StrokeThickness="2"
                         Opacity="0.25"
                         Visibility="{Binding IsBusy, Converter={StaticResource InverseBoolToVisibilityConverter}, Mode=OneWay}"
                         HorizontalAlignment="Center"
                         VerticalAlignment="Center" />
                                <FontIcon Glyph="&#xE73E;"
                          FontSize="12"
                          FontWeight="SemiBold"
                          HorizontalAlignment="Center"
                          VerticalAlignment="Center"
                          Visibility="{Binding IsBusy, Converter={StaticResource InverseBoolToVisibilityConverter}, Mode=OneWay}" />
                            </Grid>

                            <!-- File Info -->
                            <StackPanel Grid.Column="1" Margin="12,0,0,0" VerticalAlignment="Center" Spacing="4">
                                <TextBlock Text="{Binding SelectedFileName, Mode=OneWay}"
                           FontSize="15"
                           FontWeight="Medium"
                           TextTrimming="CharacterEllipsis" />
                                <TextBlock Text="{Binding IsBusy, Converter={StaticResource BoolToStatusTextConverter}, Mode=OneWay}"
                           FontSize="13"
                           Opacity="0.6" />
                            </StackPanel>

                        </Grid>
                    </Border>

                    <!-- Ticket Card -->
                    <Border Visibility="{Binding HasTicket, Converter={StaticResource BoolToVisibilityConverter}, Mode=OneWay}"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="18"
                Padding="24">

                        <StackPanel Spacing="16">

                            <Grid>
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <FontIcon Glyph="&#xE8A5;" FontSize="15" />
                                    <TextBlock Text="Transfer Ticket"
                           FontSize="15"
                           FontWeight="SemiBold"
                           VerticalAlignment="Center" />
                                </StackPanel>

                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8">
                                    <local:HandCursorButton Padding="10,6"
                            CornerRadius="8"
                            Background="Transparent"
                            BorderThickness="0.5"
                            Command="{Binding CopyTicketCommand, Mode=OneWay}">
                                        <StackPanel Orientation="Horizontal" Spacing="4">
                                            <FontIcon Glyph="&#xE77F;" FontSize="12" />
                                            <TextBlock Text="Copy" FontSize="12" FontWeight="Medium" />
                                        </StackPanel>
                                    </local:HandCursorButton>
                                    <local:HandCursorButton Padding="10,6"
                            CornerRadius="8"
                            Background="Transparent"
                            BorderThickness="0.5"
                            Command="{Binding ClearSendCommand, Mode=OneWay}">
                                        <StackPanel Orientation="Horizontal" Spacing="4">
                                            <FontIcon Glyph="&#xE894;" FontSize="12" />
                                            <TextBlock Text="Clear" FontSize="12" FontWeight="Medium" />
                                        </StackPanel>
                                    </local:HandCursorButton>
                                </StackPanel>
                            </Grid>

                            <!-- QR Code -->
                            <Border Width="200"
                    Height="200"
                    HorizontalAlignment="Center"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="16"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                                <Image Source="{Binding TicketQrImage, Mode=OneWay}"
                       Width="200"
                       Height="200"
                       Stretch="Uniform"
                       Margin="16" />
                            </Border>

                            <Border BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="12"
                    Padding="6">
                                <TextBlock Text="{Binding Ticket, Mode=OneWay}"
                       FontSize="11"
                       FontFamily="Consolas"
                       TextWrapping="Wrap"
                       IsTextSelectionEnabled="True" />
                            </Border>

                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="12">
                                <local:HandCursorButton HorizontalAlignment="Stretch"
                        Padding="0,12"
                        CornerRadius="12"
                        Command="{Binding CopyTicketCommand, Mode=OneWay}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        Background="Transparent">
                                    <StackPanel Orientation="Horizontal" Spacing="6" HorizontalAlignment="Center">
                                        <FontIcon Glyph="&#xE8C8;" FontSize="15" />
                                        <TextBlock Text="Copy" FontSize="15" FontWeight="Medium" />
                                    </StackPanel>
                                </local:HandCursorButton>
                                <local:HandCursorButton HorizontalAlignment="Stretch"
                        Padding="0,12"
                        CornerRadius="12"
                        BorderBrush="{ThemeResource TextFillColorPrimaryBrush}"
                        BorderThickness="1"
                        Background="Transparent"
                        Command="{Binding ShareTicketCommand, Mode=OneWay}">
                                    <StackPanel Orientation="Horizontal" Spacing="6" HorizontalAlignment="Center">
                                        <FontIcon Glyph="&#xE72D;" FontSize="15" />
                                        <TextBlock Text="Share" FontSize="15" FontWeight="SemiBold" />
                                    </StackPanel>
                                </local:HandCursorButton>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- Status Pill -->
                    <Border Visibility="{Binding HasStatus, Converter={StaticResource BoolToVisibilityConverter}, Mode=OneWay}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="12"
                Padding="16,10"
                HorizontalAlignment="Stretch">
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <ProgressRing IsActive="{Binding IsBusy, Mode=OneWay}"
                              Width="16"
                              Height="16"
                              Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibilityConverter}, Mode=OneWay}"
                              Foreground="{ThemeResource TextFillColorPrimaryBrush}"
                              Background="Transparent" />
                            <FontIcon Glyph="&#xE783;"
                          FontSize="12"
                          FontWeight="SemiBold"
                          Visibility="{Binding IsError, Converter={StaticResource BoolToVisibilityConverter}, Mode=OneWay}"
                          Foreground="{ThemeResource SystemFillColorCriticalBrush}"
                          VerticalAlignment="Center" />
                            <Grid Visibility="{Binding IsBusy, Converter={StaticResource InverseBoolToVisibilityConverter}, Mode=OneWay}">
                                <FontIcon Glyph="&#xE73E;"
                          FontSize="12"
                          FontWeight="SemiBold"
                          Visibility="{Binding IsError, Converter={StaticResource InverseBoolToVisibilityConverter}, Mode=OneWay}"
                          VerticalAlignment="Center" />
                            </Grid>
                            <TextBlock Text="{Binding Status, Mode=OneWay}"
                           FontSize="13"
                           FontWeight="Medium"
                           VerticalAlignment="Center" />
                        </StackPanel>
                    </Border>

                </StackPanel>

                <!-- Receive View -->
                <StackPanel Grid.Row="1"
            Spacing="24"
            HorizontalAlignment="Stretch"
            MaxWidth="720"
            Visibility="{Binding SelectedTab, Converter={StaticResource TabVisibilityConverter}, ConverterParameter=Receive, Mode=OneWay}">

                    <!-- Ticket Card -->
                    <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
            BorderThickness="1"
            CornerRadius="18"
            Padding="24"
            MaxWidth="720"
            HorizontalAlignment="Stretch">

                        <StackPanel Spacing="18">

                            <Grid>
                                <TextBlock Text="Enter ticket"
                           FontSize="15"
                           FontWeight="SemiBold"
                           VerticalAlignment="Center" />

                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8">
                                    <local:HandCursorButton Padding="10,6"
                            CornerRadius="8"
                            Background="Transparent"
                            BorderThickness="0.5"
                            Command="{Binding PasteTicketCommand, Mode=OneWay}">
                                        <StackPanel Orientation="Horizontal" Spacing="4">
                                            <FontIcon Glyph="&#xE77F;" FontSize="12" />
                                            <TextBlock Text="Paste" FontSize="12" FontWeight="Medium" />
                                        </StackPanel>
                                    </local:HandCursorButton>
                                    <local:HandCursorButton Padding="10,6"
                            CornerRadius="8"
                            Background="Transparent"
                            BorderThickness="0.5"
                            Command="{Binding ClearTicketCommand, Mode=OneWay}"
                            Visibility="{Binding HasTicketInput, Converter={StaticResource BoolToVisibilityConverter}, Mode=OneWay}">
                                        <StackPanel Orientation="Horizontal" Spacing="4">
                                            <FontIcon Glyph="&#xE894;" FontSize="12" />
                                            <TextBlock Text="Clear" FontSize="12" FontWeight="Medium" />
                                        </StackPanel>
                                    </local:HandCursorButton>
                                </StackPanel>
                            </Grid>

                            <TextBox Text="{Binding TicketInput, Mode=TwoWay}"
                     PlaceholderText="Paste ticket here..."
                     AcceptsReturn="True"
                     MinHeight="72"
                     TextWrapping="Wrap"
                     Padding="10"
                     FontFamily="Consolas"
                     FontSize="11"
                     CornerRadius="12" />
                        </StackPanel>
                    </Border>

                    <!-- Save Location Card -->
                    <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
            BorderThickness="1"
            CornerRadius="18"
            Padding="24"
            MaxWidth="720"
            HorizontalAlignment="Stretch">

                        <StackPanel Spacing="18">

                            <Grid>
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <FontIcon Glyph="&#xE8D4;" FontSize="18" />
                                    <TextBlock Text="Save Location"
                               FontSize="15"
                               FontWeight="SemiBold" />
                                </StackPanel>

                                <local:HandCursorButton Content="Change"
                        HorizontalAlignment="Right"
                        Background="Transparent"
                        BorderThickness="0"
                        Command="{Binding SelectDestinationCommand, Mode=OneWay}" />
                            </Grid>

                            <Border BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="14"
                    Padding="14">

                                <StackPanel Orientation="Horizontal" Spacing="12">
                                    <FontIcon Glyph="&#xE8B7;" FontSize="20" />

                                    <StackPanel>
                                        <TextBlock Text="{Binding DestinationName, Mode=OneWay}"
                                   FontSize="14"
                                   FontWeight="Medium" />

                                        <TextBlock Text="{Binding DestinationPath, Mode=OneWay}"
                                   FontSize="12"
                                   Opacity="0.6"
                                   TextTrimming="CharacterEllipsis" />
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Border>

                    <!-- Receive Button -->
                    <local:HandCursorButton HorizontalAlignment="Stretch"
            Padding="0,12"
            CornerRadius="12"
            Command="{Binding ReceiveCommand, Mode=OneWay}"
            IsEnabled="{Binding HasTicketInput, Mode=OneWay}"
            BorderBrush="{ThemeResource TextFillColorPrimaryBrush}"
            BorderThickness="1"
            Background="Transparent">
                        <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Center">
                            <FontIcon Glyph="&#xE896;" FontSize="18" />
                            <TextBlock Text="Receive File" FontSize="15" FontWeight="SemiBold" />
                        </StackPanel>
                    </local:HandCursorButton>

                    <!-- Status Pill -->
                    <Border Visibility="{Binding HasStatus, Converter={StaticResource BoolToVisibilityConverter}, Mode=OneWay}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="12"
                Padding="16,10"
                HorizontalAlignment="Stretch">
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <ProgressRing IsActive="{Binding IsBusy, Mode=OneWay}"
                              Width="16"
                              Height="16"
                              Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibilityConverter}, Mode=OneWay}"
                              Foreground="{ThemeResource TextFillColorPrimaryBrush}"
                              Background="Transparent" />
                            <FontIcon Glyph="&#xE783;"
                          FontSize="12"
                          FontWeight="SemiBold"
                          Visibility="{Binding IsError, Converter={StaticResource BoolToVisibilityConverter}, Mode=OneWay}"
                          Foreground="{ThemeResource SystemFillColorCriticalBrush}"
                          VerticalAlignment="Center" />
                            <Grid Visibility="{Binding IsBusy, Converter={StaticResource InverseBoolToVisibilityConverter}, Mode=OneWay}">
                                <FontIcon Glyph="&#xE73E;"
                          FontSize="12"
                          FontWeight="SemiBold"
                          Visibility="{Binding IsError, Converter={StaticResource InverseBoolToVisibilityConverter}, Mode=OneWay}"
                          VerticalAlignment="Center" />
                            </Grid>
                            <TextBlock Text="{Binding Status, Mode=OneWay}"
                           FontSize="13"
                           FontWeight="Medium"
                           VerticalAlignment="Center" />
                        </StackPanel>
                    </Border>

                    <TextBlock Text="Once you enter a valid ticket, the files will be ready to download."
               FontSize="13"
               Opacity="0.55"
               HorizontalAlignment="Center"
               TextAlignment="Center"
               TextWrapping="Wrap" />
                </StackPanel>
            </Grid>
        </ScrollViewer>

    </Grid>
</Window>